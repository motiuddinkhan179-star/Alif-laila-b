rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, name, email, mobile, role, location, shopName, walletBalance, status, sellerId, isOnline, paymentType, salary, deliveryCharge
    //
    // Collection: products
    // Fields: id, sellerId, name, price, image, category, description, location
    //
    // Collection: orders
    // Fields: id, customerId, sellerId, items, totalAmount, platformFee, sellerAmount, status, createdAt, paymentStatus
    //
    // Collection: notifications
    // Fields: userId, title, message, type, read, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             (('email' in request.auth.token) && (
              request.auth.token.email.lower() == "khanmohammadahmad597@gmail.com" ||
              request.auth.token.email.lower() == "khanmohammadahmad1@gmail.com" ||
              request.auth.token.email.lower() == "khanmohammadahmad@gmail.com" ||
              request.auth.token.email.lower() == "khanmohammadahmad2@gmail.com" ||
              request.auth.token.email.lower() == "khanmohammadahmad3@gmail.com" ||
              request.auth.token.email.lower() == "system@aliflaila.com"
             ) ||
              (request.auth.token.email_verified == true && 
               exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isDeliveryBoy() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'delivery_boy';
    }

    function isSellerEmail(email) {
      return email != null && email.lower() in [
        "khanmohammadahmad597@gmail.com",
        "khanmohammadahmad@gmail.com",
        "khanmohammadahmad3@gmail.com",
        "khanmohammadahmad1@gmail.com"
      ];
    }

    function isSeller() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }

    function isValidUser(data) {
      return data.name is string && data.name.size() < 100 &&
             data.role in ['customer', 'seller', 'admin', 'delivery_boy'] &&
             data.uid == request.auth.uid &&
             data.email is string &&
             (!('mobile' in data) || (data.mobile is string && data.mobile.size() < 25)) &&
             (!('status' in data) || (data.status in ['approved', 'pending', 'blocked'])) &&
             (!('walletBalance' in data) || data.walletBalance is number) &&
             (!('isOnline' in data) || data.isOnline is bool) &&
             (!('sellerId' in data) || (data.sellerId is string)) &&
             (!('paymentType' in data) || (data.paymentType in ['fixed', 'per_delivery'])) &&
             (!('salary' in data) || data.salary is number) &&
             (!('deliveryCharge' in data) || data.deliveryCharge is number) &&
             (!('shopName' in data) || (data.shopName is string && data.shopName.size() < 100)) &&
             (!('shopAddress' in data) || (data.shopAddress is string && data.shopAddress.size() < 200)) &&
             (!('shopCategory' in data) || (data.shopCategory is string && data.shopCategory.size() < 50)) &&
             (!('aadhaarNumber' in data) || (data.aadhaarNumber is string && data.aadhaarNumber.size() < 20)) &&
             (!('panNumber' in data) || (data.panNumber is string && data.panNumber.size() < 20)) &&
             (!('licenseNumber' in data) || (data.licenseNumber is string && data.licenseNumber.size() < 50)) &&
             (!('upiId' in data) || (data.upiId is string && data.upiId.size() < 100)) &&
             (!('deliveryRadius' in data) || data.deliveryRadius is number) &&
             (!('deliveryFee' in data) || data.deliveryFee is number) &&
             (!('address' in data) || data.address is string) &&
             (!('fullAddress' in data) || data.fullAddress is string) &&
             (!('applicationDate' in data) || data.applicationDate is string) &&
             (!('createdAt' in data) || data.createdAt is string) &&
             (!('serverSecret' in data) || (data.serverSecret is string && data.serverSecret.size() < 100)) &&
             (!('location' in data) || (data.location is map && data.location.lat is number && data.location.lng is number));
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() < 50 &&
             data.sellerId == request.auth.uid &&
             (!('expiryTime' in data) || data.expiryTime == null || data.expiryTime is string) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    function isValidOrder(data) {
      return data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'accepted', 'ready', 'out_for_delivery', 'delivered', 'rejected'];
    }

    function isValidNotification(data) {
      return data.userId is string &&
             data.title is string && data.title.size() < 100 &&
             data.message is string && data.message.size() < 500 &&
             data.type in ['order', 'system', 'payment'] &&
             data.read is bool &&
             data.createdAt is string &&
             (!('serverSecret' in data) || (data.serverSecret is string && data.serverSecret.size() < 100));
    }

    function isValidTransaction(data) {
      return data.userId is string &&
             data.amount is number &&
             data.type in ['earning', 'withdrawal', 'payment', 'refund', 'fee', 'deposit'] &&
             data.status in ['completed', 'pending', 'failed'] &&
             data.description is string && data.description.size() < 200 &&
             (!('upiId' in data) || (data.upiId is string && data.upiId.size() < 100));
    }

    // Users rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || 
                    (isSeller() && get(/databases/$(database)/documents/users/$(userId)).data.sellerId == request.auth.uid) ||
                    resource.data.serverSecret == "alif-laila-push-secret-2026";
      allow list: if (isAuthenticated() && (
        isAdmin() || 
        (request.query.limit <= 10 && ('email' in request.auth.token) && request.query.filters.email == request.auth.token.email.lower()) ||
        (request.query.filters.role == 'seller' && request.query.filters.status == 'approved') ||
        (isSeller() && request.query.filters.sellerId == request.auth.uid)
      )) || (request.query.filters.serverSecret == "alif-laila-push-secret-2026");
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'customer' || 
                     (request.resource.data.role == 'seller' && isSellerEmail(request.auth.token.email)) ||
                     (request.resource.data.role == 'delivery_boy') ||
                     isAdmin()) &&
                    request.resource.data.walletBalance == 0;
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                       (request.resource.data.role == resource.data.role || isAdmin()) &&
                       (request.resource.data.walletBalance == resource.data.walletBalance || 
                        request.resource.data.walletBalance < resource.data.walletBalance || isAdmin())) || 
                    (isSeller() && get(/databases/$(database)/documents/users/$(userId)).data.sellerId == request.auth.uid && 
                     isValidUser(request.resource.data)) ||
                    isAdmin();
    }

    // Products rules
    match /products/{productId} {
      allow read: if true;
      allow create: if isSeller() && isValidProduct(request.resource.data);
      allow update: if isSeller() && resource.data.sellerId == request.auth.uid && isValidProduct(request.resource.data);
      allow delete: if isSeller() && resource.data.sellerId == request.auth.uid;
    }

    // Orders rules
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid || 
        (isDeliveryBoy() && resource.data.sellerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sellerId) ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) &&
                    request.resource.data.customerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        (resource.data.customerId == request.auth.uid && request.resource.data.status == 'pending' && resource.data.status == 'pending') || 
        (resource.data.sellerId == request.auth.uid && isValidOrder(request.resource.data) && 
         request.resource.data.customerId == resource.data.customerId) || 
        (isDeliveryBoy() && resource.data.sellerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sellerId &&
         (request.resource.data.status == 'out_for_delivery' || request.resource.data.status == 'delivered')) ||
        isAdmin()
      );
    }

    // Notifications rules
    match /notifications/{notificationId} {
      allow read: if (isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin())) || 
                  (resource.data.serverSecret == "alif-laila-push-secret-2026");
      allow list: if (isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin())) || 
                  (request.query.filters.serverSecret == "alif-laila-push-secret-2026");
      allow create: if isAuthenticated(); // Allow users to send notifications (e.g. to sellers)
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) || isAdmin());
    }

    // Transactions rules
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && 
                    isValidTransaction(request.resource.data) &&
                    (request.resource.data.type in ['withdrawal', 'payment', 'deposit'] || isAdmin());
      allow update: if isAdmin();
    }

    // Connection test rule
    match /_connection_test_/{docId} {
      allow read: if true;
    }
  }
}
