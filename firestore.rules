rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, name, email, mobile, role, location, shopName, walletBalance, status
    //
    // Collection: products
    // Fields: id, sellerId, name, price, image, category, description, location
    //
    // Collection: orders
    // Fields: id, customerId, sellerId, items, totalAmount, platformFee, sellerAmount, status, createdAt, paymentStatus
    //
    // Collection: notifications
    // Fields: userId, title, message, type, read, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "khanmohammadahmad597@gmail.com" && request.auth.token.email_verified == true));
    }

    function isSeller() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }

    function isValidUser(data) {
      return data.name is string && data.name.size() < 100 &&
             data.role in ['customer', 'seller', 'admin'] &&
             (!('mobile' in data) || (data.mobile is string && data.mobile.size() < 20)) &&
             (!('status' in data) || (data.status in ['approved', 'pending', 'blocked'])) &&
             (!('shopName' in data) || (data.shopName is string && data.shopName.size() < 100)) &&
             (!('upiId' in data) || (data.upiId is string && data.upiId.size() < 100));
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() < 50 &&
             data.sellerId == request.auth.uid &&
             (!('expiryTime' in data) || data.expiryTime == null || data.expiryTime is string) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    function isValidOrder(data) {
      return data.customerId == request.auth.uid &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'accepted', 'out_for_delivery', 'delivered', 'rejected'];
    }

    function isValidNotification(data) {
      return data.userId is string &&
             data.title is string && data.title.size() < 100 &&
             data.message is string && data.message.size() < 500 &&
             data.type in ['order', 'system', 'payment'] &&
             data.read is bool &&
             data.createdAt is string;
    }

    function isValidTransaction(data) {
      return data.userId is string &&
             data.amount is number &&
             data.type in ['earning', 'withdrawal', 'payment', 'refund', 'fee', 'deposit'] &&
             data.status in ['pending', 'completed', 'failed'] &&
             data.description is string && data.description.size() < 200 &&
             (!('upiId' in data) || (data.upiId is string && data.upiId.size() < 100));
    }

    // Users rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
    }

    // Products rules
    match /products/{productId} {
      allow read: if true;
      allow create: if isSeller() && isValidProduct(request.resource.data);
      allow update: if isSeller() && resource.data.sellerId == request.auth.uid && isValidProduct(request.resource.data);
      allow delete: if isSeller() && resource.data.sellerId == request.auth.uid;
    }

    // Orders rules
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.sellerId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.customerId == request.auth.uid && request.resource.data.status == 'pending') || 
        (resource.data.sellerId == request.auth.uid && isValidOrder(request.resource.data)) || 
        isAdmin()
      );
    }

    // Notifications rules
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    // Transactions rules
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidTransaction(request.resource.data);
      allow update: if isAdmin();
    }

    // Connection test rule
    match /_connection_test_/{docId} {
      allow read: if true;
    }
  }
}
